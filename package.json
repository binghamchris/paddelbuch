{
  "name": "@binghamchris/paddelbuch",
  "title": "Swiss Paddle Sports Map",
  "description": "A Swiss paddle sports map built with Jekyll",
  "version": "2.0.0",
  "private": true,
  "author": {
    "name": "Chris Bingham"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "copy-assets": "node scripts/copy-vendor-assets.js",
    "download-fonts": "node scripts/download-google-fonts.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:property": "jest --testPathPatterns=property"
  },
  "keywords": [
    "Swiss Canoe",
    "Jekyll",
    "Paddle Sports"
  ],
  "dependencies": {
