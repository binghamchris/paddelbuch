    "bootstrap": "5.3.8",
    "chart.js": "4.5.1",
    "leaflet": "1.9.4",
    "leaflet.locatecontrol": "0.90.0",
    "maplibre-gl": "5.24.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "fast-check": "4.8.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "sass": "1.101.0"
  }
}
